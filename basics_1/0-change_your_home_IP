#!/usr/bin/env bash
# Configures /etc/hosts so localhost resolves to 127.0.0.2 and facebook.com to 8.8.8.8

TMP=$(mktemp)
grep -vE '^\s*(127\.0\.0\.1\s+localhost|.*facebook\.com)' /etc/hosts > "$TMP"
echo "127.0.0.2 localhost" >> "$TMP"
echo "8.8.8.8 facebook.com" >> "$TMP"
cp "$TMP" /etc/hosts
rm "$TMP"
